#!/usr/bin/env bash
# Mock qvm-run: the installer's ONLY VM->dom0 dataflow is
#   qvm-run -p REPO_VM "git ... cat-file ... && git ... archive ..."
# Emit that archive on stdout. SEQS_MOCK_TAR (a path) overrides the payload so a
# scenario can feed a hostile archive; otherwise archive the requested commit.
case "$*" in
  *"cat-file -e ${SEQS_EXPECTED_COMMIT:?SEQS_EXPECTED_COMMIT unset}^{commit}"*"archive --format=tar ${SEQS_EXPECTED_COMMIT} -- salt install-scripts"*) ;;
  *) exit 64 ;;
esac
if [ -n "${SEQS_MOCK_TAR:-}" ]; then
  cat "${SEQS_MOCK_TAR}"
else
  git -C "${SEQS_REPO_ROOT:?SEQS_REPO_ROOT unset}" archive --format=tar \
    "${SEQS_EXPECTED_COMMIT:?SEQS_EXPECTED_COMMIT unset}" -- salt install-scripts
fi
