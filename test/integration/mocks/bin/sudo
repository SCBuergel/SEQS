#!/usr/bin/env bash
# Mock sudo: strip leading options (-n, -u user, ...) then exec the command.
# The sandbox dirs are user-writable, so no real privilege is needed.
if [ -n "${SEQS_MOCK_SUDO_LOG:-}" ]; then
  printf '%q ' "$@" >> "${SEQS_MOCK_SUDO_LOG}"
  printf '\n' >> "${SEQS_MOCK_SUDO_LOG}"
fi
while [ $# -gt 0 ]; do
  case "$1" in
    -n|-E|-H|-k) shift ;;
    -u) shift 2 ;;
    --) shift; break ;;
    -*) shift ;;
    *) break ;;
  esac
done
# The unprivileged test container cannot chown to root; production sudo can.
if [ "${1:-}" = "chown" ]; then
  exit 0
fi
exec "$@"
