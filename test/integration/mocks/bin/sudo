#!/usr/bin/env bash
# Mock sudo: strip leading options (-n, -u user, ...) then exec the command.
# The sandbox dirs are user-writable, so no real privilege is needed.
while [ $# -gt 0 ]; do
  case "$1" in
    -n|-E|-H|-k) shift ;;
    -u) shift 2 ;;
    --) shift; break ;;
    -*) shift ;;
    *) break ;;
  esac
done
exec "$@"
